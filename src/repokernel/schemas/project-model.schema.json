{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "repokernel.project-model.v1",
  "title": "ProjectModel",
  "type": "object",
  "required": ["schema", "identity", "mission", "product_or_result", "source_refs", "assertions", "boundaries", "unknowns"],
  "additionalProperties": false,
  "properties": {
    "schema": { "const": "repokernel.project-model.v1" },
    "identity": { "type": "object" },
    "mission": { "type": "string", "minLength": 1 },
    "product_or_result": { "type": "string", "minLength": 1 },
    "source_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "assertions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "status", "text"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "status": { "enum": ["verified", "inferred", "conflict", "unknown"] },
          "text": { "type": "string", "minLength": 1 },
          "source_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } }
        },
        "allOf": [
          {
            "if": { "properties": { "status": { "enum": ["verified", "inferred", "conflict"] } }, "required": ["status"] },
            "then": { "required": ["source_refs"], "properties": { "source_refs": { "minItems": 1 } } }
          }
        ]
      }
    },
    "boundaries": { "type": "object" },
    "unknowns": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "source_conflicts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "summary", "source_refs"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "summary": { "type": "string", "minLength": 1 },
          "source_refs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
        }
      }
    },
    "extensions": {
      "type": "object",
      "propertyNames": { "pattern": "^[a-z0-9][a-z0-9_-]*(\\.[a-z0-9][a-z0-9_-]*)+$" }
    }
  }
}
