{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "repokernel.activation-report.v1",
  "title": "ActivationReport",
  "type": "object",
  "required": ["schema", "state", "checks"],
  "properties": {
    "schema": { "const": "repokernel.activation-report.v1" },
    "state": { "enum": ["planned", "generated", "validated", "active", "blocked"] },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "ok"],
        "properties": {
          "id": { "type": "string" },
          "ok": { "type": "boolean" },
          "message": { "type": "string" }
        }
      }
    },
    "blocked_reasons": { "type": "array", "items": { "type": "string" } },
    "extensions": { "type": "object", "propertyNames": { "pattern": "^[a-z0-9][a-z0-9_-]*(\\.[a-z0-9][a-z0-9_-]*)+$" } }
  }
}
