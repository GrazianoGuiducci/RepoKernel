{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "repokernel.seed-spec.v1",
  "title": "SeedSpec",
  "type": "object",
  "required": [
    "schema",
    "version",
    "seed_id",
    "source_manifest_hash",
    "project_model_hash",
    "canonical_namespace",
    "project",
    "target",
    "readiness_level",
    "authority_mode",
    "review",
    "compiler_compatibility",
    "file_plan_policy",
    "validation_plan"
  ],
  "additionalProperties": false,
  "properties": {
    "schema": { "const": "repokernel.seed-spec.v1" },
    "version": { "const": "repokernel.seed-spec.v1" },
    "seed_id": { "type": "string", "minLength": 1 },
    "source_manifest_hash": { "type": "string", "pattern": "^[A-Fa-f0-9]{64}$" },
    "project_model_hash": { "type": "string", "pattern": "^[A-Fa-f0-9]{64}$" },
    "canonical_namespace": { "const": ".repokernel" },
    "project": {
      "type": "object",
      "required": ["name", "intent", "product"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "intent": { "type": "string", "minLength": 1 },
        "product": { "type": "string", "minLength": 1 },
        "domain": { "type": "string" },
        "users": { "type": "array", "items": { "type": "string" } }
      }
    },
    "target": {
      "type": "object",
      "required": ["mode"],
      "additionalProperties": false,
      "properties": {
        "mode": { "enum": ["new_repository", "existing_repository_retrofit"] },
        "path": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!/)(?!//)(?!.*:)(?!.*(^|/)\\.\\.?($|/)).+"
        }
      }
    },
    "readiness_level": { "enum": ["L0", "L1", "L2", "L3"] },
    "authority_mode": { "enum": ["none", "read", "propose", "proposal_only"] },
    "review": {
      "type": "object",
      "required": ["status", "accepted_by_role", "accepted_at", "review_cycle"],
      "additionalProperties": false,
      "properties": {
        "status": { "const": "accepted" },
        "accepted_by_role": { "type": "string", "minLength": 1 },
        "accepted_at": { "type": "string", "minLength": 1 },
        "review_cycle": { "type": "string", "minLength": 1 }
      }
    },
    "compiler_compatibility": {
      "type": "object",
      "required": ["package_version"],
      "additionalProperties": true,
      "properties": {
        "package_version": { "type": "string", "minLength": 1 },
        "contract_versions": { "type": "object" }
      }
    },
    "file_plan_policy": { "enum": ["stage_only", "proposal_only"] },
    "validation_plan": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "disclosure": { "type": "object" },
    "lineage": { "type": "object" },
    "lifecycle": { "type": "object" },
    "extensions": { "type": "object", "propertyNames": { "pattern": "^[a-z0-9][a-z0-9_-]*(\\.[a-z0-9][a-z0-9_-]*)+$" } }
  }
}
