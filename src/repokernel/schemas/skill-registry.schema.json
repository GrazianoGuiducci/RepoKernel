{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "repokernel.skill-registry.v1",
  "title": "SkillRegistry",
  "type": "object",
  "required": ["schema", "skills"],
  "additionalProperties": false,
  "properties": {
    "schema": { "enum": ["repokernel.skill-registry.v1", "repokernel.skill-registry.v2"] },
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "state", "path", "risk", "evidence"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
          "version": { "type": "string" },
          "state": { "enum": ["draft", "candidate", "accepted", "promoted", "private", "residue"] },
          "path": { "type": "string", "minLength": 1 },
          "risk": { "enum": ["low", "medium", "high", "critical"] },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "extensions": {
      "type": "object",
      "propertyNames": { "pattern": "^[a-z0-9][a-z0-9_-]*(\\.[a-z0-9][a-z0-9_-]*)+$" }
    }
  }
}
