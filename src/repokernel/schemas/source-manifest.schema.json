{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "repokernel.source-manifest.v1",
  "title": "SourceManifest",
  "type": "object",
  "required": ["schema", "sources"],
  "additionalProperties": false,
  "properties": {
    "schema": { "const": "repokernel.source-manifest.v1" },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["source_id", "authority", "privacy", "used_for"],
        "additionalProperties": false,
        "properties": {
          "source_id": { "type": "string", "minLength": 1 },
          "path_or_origin": { "type": "string" },
          "authority": { "enum": ["operator", "maintainer", "repo", "example", "external_review", "generated"] },
          "privacy": { "enum": ["public", "internal", "private", "withheld"] },
          "public_label": { "type": "string", "minLength": 1 },
          "freshness": { "enum": ["current", "stale", "historical", "unknown"] },
          "instruction_handling": { "enum": ["data_only", "trusted_instruction", "operator_instruction"] },
          "sha256": { "type": "string", "pattern": "^[A-Fa-f0-9]{64}$" },
          "used_for": { "type": "array", "items": { "type": "string" } },
          "withheld_reason": { "type": ["string", "null"] }
        }
      }
    },
    "extensions": { "type": "object", "propertyNames": { "pattern": "^[a-z0-9][a-z0-9_-]*(\\.[a-z0-9][a-z0-9_-]*)+$" } }
  }
}
