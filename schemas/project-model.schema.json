{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "repokernel.project-model.v1",
  "title": "ProjectModel",
  "type": "object",
  "required": ["schema", "identity", "mission", "product_or_result", "source_refs", "boundaries", "unknowns"],
  "properties": {
    "schema": { "const": "repokernel.project-model.v1" },
    "identity": { "type": "object" },
    "mission": { "type": "string" },
    "product_or_result": { "type": "string" },
    "source_refs": { "type": "array", "items": { "type": "string" } },
    "boundaries": { "type": "object" },
    "unknowns": { "type": "array", "items": { "type": "string" } },
    "source_conflicts": { "type": "array" },
    "extensions": { "type": "object" }
  }
}
